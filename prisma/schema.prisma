generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  jobs         Job[]
  coverLetters CoverLetter[]
  scrapeLogs   ScrapeLog[]
  profile      CandidateProfile?
}

model Job {
  id               String    @id @default(cuid())
  userId           String
  title            String
  company          String
  companyLogo      String?
  location         String
  salary           String?
  description      String
  shortDescription String?
  url              String
  source           Source
  tags             String[]
  remote           Boolean   @default(true)
  status           JobStatus @default(NEW)
  seniority        Seniority?
  matchScore       Int?
  appliedAt        DateTime?
  notes            String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  coverLetter      CoverLetter?

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId, status])
  @@index([userId, source])
  @@index([userId, createdAt])
}

model CoverLetter {
  id        String   @id @default(cuid())
  userId    String
  content   String
  jobId     String   @unique
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ScrapeLog {
  id        String   @id @default(cuid())
  userId    String
  source    Source
  jobsFound Int
  newJobs   Int
  errors    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CandidateProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  summary   String
  resumeText      String?
  resumeFileName  String?
  resumeMime      String?
  resumeUpdatedAt DateTime?
  resumeHighlights String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Source {
  REMOTEOK
  WEWORKREMOTELY
  ARBEITNOW
  REMOTIVE
  HIMALAYAS
  JOBICY
  THEMUSE
  MANUAL
}

enum Seniority {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
  STAFF
  PRINCIPAL
}

enum JobStatus {
  NEW
  SAVED
  APPLIED
  INTERVIEW
  REJECTED
  OFFER
}
